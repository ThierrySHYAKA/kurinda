# Python
__pycache__/
*.py[cod]
*.so
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/

# Node
node_modules/
.next/
out/
.turbo/

# Environment
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Data
# Raw sources are large or licensed — NEVER commit
data/raw/

# Block large/raw data formats by default, anywhere in the repo
*.csv
*.parquet
*.zip
*.shp
*.geojson

# Un-ignore processed outputs (small aggregates, safe to commit)
!data/processed/
!data/processed/**

# Preserve existing docs exception
!docs/**/*.geojson

# Model artefacts
*.pkl
*.joblib
*.h5
